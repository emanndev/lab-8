{
     "compilerOptions": {
       "target": "ES6",
       "module": "ESNext",
       "strict": true,
       "esModuleInterop": true,
       "skipLibCheck": true,
       "moduleResolution": "node",
       "outDir": "./dist",
       "rootDir": "./src",
       "sourceMap": true,
       "resolveJsonModule": true,
       "types": ["jest", "node"]
     },
     "include": ["src/**/*"],
     "exclude": ["node_modules", "dist"]
   }