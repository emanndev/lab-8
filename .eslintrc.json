{
     "env": {
       "browser": true,
       "es2021": true
     },
     "extends": [
       "airbnb-base",
       "plugin:@typescript-eslint/recommended",
       "plugin:prettier/recommended"
     ],
     "parser": "@typescript-eslint/parser",
     "parserOptions": {
       "ecmaVersion": 12,
       "sourceType": "module"
     },
     "plugins": [
       "@typescript-eslint",
       "prettier"
     ],
     "rules": {
       "prettier/prettier": "error",
       "no-console": "warn",
       "max-len": ["error", { "code": 120 }],
       "@typescript-eslint/no-unused-vars": ["error"]
     }
   }